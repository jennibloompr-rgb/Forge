---
import Base from '../../layouts/Base.astro';
import { getSettings } from '../../lib/content';

const { site } = await getSettings();
const email = site.contactEmail ?? 'hello@weforgepartnerships.com';
const TYPEFORM = 'https://form.typeform.com/to/fs7AGMov';

const buyers = ['Waitrose', 'Ocado', 'CN Foods', 'ISS'];

const details = [
  { n: '01', k: 'The buyers', v: '50 qualified', note: 'Vetted retail and foodservice buyers actively looking to list.' },
  { n: '02', k: 'The brands', v: '30 brands', note: 'Founder-run, by application, ready to supply at scale.' },
  { n: '03', k: 'The format', v: 'One day', note: 'One room, face to face with buyers. Not a noisy hall.' },
  { n: '04', k: 'The place', v: 'A Georgian house', note: 'A private house in Norfolk, lunch and the room included.' },
];

const steps = [
  { n: '01', title: 'Apply', body: 'Tell us about your brand, your range and where you already sell. It takes a few minutes.' },
  { n: '02', title: 'Get your place', body: 'We review every application and select the brands that are ready to meet buyers on the day.' },
  { n: '03', title: 'Meet the buyer', body: 'Spend the day in one room with the people who place the orders, meeting them face to face.' },
];

const faqs = [
  { q: 'Who are the buyers?', a: 'Qualified retail and foodservice buyers with live listing budgets — names like Waitrose and Ocado among them. We vet every buyer before they walk in.' },
  { q: 'How does the day work?', a: 'Qualified buyers and selected brands spend the day together in one room. You meet buyers face to face — no giant hall, no working the floor hoping to be noticed.' },
  { q: 'What does it cost?', a: 'It is £395 per brand for the day, including your meetings, lunch and the venue. Buyers attend as our guests.' },
  { q: 'Where is it held?', a: 'A private Georgian house in Norfolk. Full travel and timing details go out to confirmed brands once applications close.' },
  { q: 'Do I have to be a Forge member?', a: 'No. Meet the Buyer is open by application to any founder-run brand ready to supply, members and non-members alike. Members get first call on seats.' },
  { q: 'What if I am not ready to supply at scale?', a: 'Then this is not the right room yet, and we will say so. The day works because every brand in it can actually fulfil an order.' },
];

const headStyle = `
  .mtb-faq[open] .mtb-faq-chev { transform: rotate(45deg); }
  summary { list-style: none; cursor: pointer; }
  summary::-webkit-details-marker { display: none; }
  @media (max-width: 880px) {
    .forge-nav-links { display: none !important; }
    .mtb-grid-2 { grid-template-columns: 1fr !important; }
    .mtb-grid-4 { grid-template-columns: 1fr 1fr !important; }
    .mtb-grid-3 { grid-template-columns: 1fr !important; }
    .forge-pad { padding-left: 22px !important; padding-right: 22px !important; }
    .mtb-logos { gap: 24px 32px !important; }
  }
`;
---

<Base
  title="Meet the Buyer — 50 qualified buyers, 30 brands, one day | The Forge"
  description="A curated buying day for founder-run food & drink brands. 50 qualified buyers, 30 brands, one room in a Georgian house in Norfolk. £395 per brand, by application."
  bodyBackground="#FCFBF4"
  selectionBg="#1E1BD1"
  selectionColor="#FFFFFF"
  path="/network/buyer"
  fontHref="https://fonts.googleapis.com/css2?family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;0,6..72,600;1,6..72,400;1,6..72,500;1,6..72,600&family=Hanken+Grotesk:wght@400;500;600;700;800&display=swap"
  headStyle={headStyle}
>
  <div style="font-family: 'Hanken Grotesk', -apple-system, sans-serif; color: #1A1A22; background: #FCFBF4; position: relative; overflow-x: hidden; -webkit-font-smoothing: antialiased;">

    <!-- ============ NAV (network section) ============ -->
    <nav style="position: sticky; top: 0; z-index: 100; background: rgba(252,251,244,0.9); backdrop-filter: blur(14px); border-bottom: 1px solid rgba(26,26,34,0.1);">
      <div class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 16px 44px; display: flex; align-items: center; justify-content: space-between; gap: 24px;">
        <div style="display: flex; align-items: baseline; gap: 14px;">
          <a href="/" style="text-decoration: none; font-family: 'Arial Black', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 900; font-style: italic; font-size: 25px; letter-spacing: -0.045em; color: #1E1BD1; line-height: 1;">TheForge</a>
          <span style="font-family: 'Newsreader', Georgia, serif; font-style: italic; font-size: 18px; color: #55555F;">meet the buyer</span>
        </div>
        <div class="forge-nav-links" style="display: flex; align-items: center; gap: 32px; font-family: 'Hanken Grotesk', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: #44444F;">
          <a href="#about" style="text-decoration: none;">What it is</a>
          <a href="#details" style="text-decoration: none;">Event details</a>
          <a href="#faqs" style="text-decoration: none;">FAQs</a>
          <a href="/network" style="text-decoration: none;">← The hall</a>
        </div>
        <a href={TYPEFORM} target="_blank" rel="noopener" class="pill-indigo" style="text-decoration: none; font-family: 'Hanken Grotesk', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 11px 20px; border-radius: 999px; background: #1E1BD1; color: #FFFFFF; transition: background 0.15s;">Apply now</a>
      </div>
    </nav>

    <!-- ============ HERO ============ -->
    <header class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 90px 44px 80px; text-align: center;">
      <div data-reveal style="font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #1E1BD1; margin-bottom: 30px;">A Forge buying day · By application</div>
      <h1 data-reveal style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(40px, 7vw, 92px); line-height: 1.02; letter-spacing: -0.02em; margin: 0 auto; max-width: 1000px; color: #14141C; text-wrap: balance;">50 qualified buyers. 30 brands. <span style="font-style: italic; color: #1E1BD1;">One day where orders happen.</span></h1>
      <p data-reveal style="font-family: 'Hanken Grotesk', sans-serif; font-size: clamp(16px, 1.7vw, 19px); font-weight: 500; line-height: 1.65; color: #44444F; max-width: 620px; margin: 32px auto 0; text-wrap: pretty;">Not a trade show. A curated buying day where founder-run brands meet the people who actually place the orders — face to face, in one room.</p>
      <div data-reveal style="display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: 36px;">
        <a href={TYPEFORM} target="_blank" rel="noopener" class="pill-indigo" style="text-decoration: none; font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 16px 30px; border-radius: 999px; background: #1E1BD1; color: #FFFFFF; transition: background 0.15s;">Apply now</a>
        <a href="#faqs" class="pill-outline" style="text-decoration: none; font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 16px 30px; border-radius: 999px; background: transparent; border: 1.5px solid rgba(26,26,34,0.28); color: #14141C; transition: all 0.15s;">Read the FAQs</a>
      </div>
    </header>

    <!-- ============ BUYER LOGOS ============ -->
    <section style="border-top: 1px solid rgba(26,26,34,0.1); border-bottom: 1px solid rgba(26,26,34,0.1); background: #FFFFFF;">
      <div class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 36px 44px;">
        <div data-reveal style="text-align: center; font-family: 'Hanken Grotesk', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.18em; text-transform: uppercase; color: #8A8A95; margin-bottom: 24px;">Buyers in the room have come from</div>
        <div class="mtb-logos" data-reveal style="display: flex; flex-wrap: wrap; align-items: center; justify-content: center; gap: 32px 64px;">
          {buyers.map((b) => (
            <span style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(22px, 3vw, 32px); letter-spacing: 0.01em; color: #44444F;">{b}</span>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ WHAT IT IS ============ -->
    <section id="about" class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 100px 44px;">
      <div class="mtb-grid-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">
        <div data-reveal>
          <div style="font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #1E1BD1; margin-bottom: 22px;">What it is</div>
          <h2 style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(30px, 4.4vw, 52px); line-height: 1.08; letter-spacing: -0.02em; margin: 0 0 20px; color: #14141C; text-wrap: pretty;">A buying day engineered so the meetings actually land.</h2>
          <p style="font-family: 'Newsreader', Georgia, serif; font-style: italic; font-size: clamp(21px, 2.6vw, 28px); line-height: 1.25; color: #1E1BD1; margin: 0;">we do the matching, so you do the selling.</p>
        </div>
        <div data-reveal>
          <p style="font-family: 'Hanken Grotesk', sans-serif; font-size: 17px; font-weight: 500; line-height: 1.7; color: #3A3A45; margin: 0 0 18px;">Trade shows put you in a hall and wish you luck. Meet the Buyer does the opposite. We qualify every buyer and review every brand, so the whole room is worth your morning.</p>
          <p style="font-family: 'Hanken Grotesk', sans-serif; font-size: 17px; font-weight: 500; line-height: 1.7; color: #3A3A45; margin: 0;">You spend the day in front of people who can place an order, and leave with conversations that go somewhere — not a tote bag of business cards.</p>
        </div>
      </div>
    </section>

    <!-- ============ THE OPPORTUNITY (full-bleed blue) ============ -->
    <section style="background: #1E1BD1; color: #FFFFFF;">
      <div class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 110px 44px; text-align: center;">
        <div data-reveal style="font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: rgba(255,255,255,0.7); margin-bottom: 28px;">The opportunity</div>
        <h2 data-reveal style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(30px, 5vw, 62px); line-height: 1.08; letter-spacing: -0.02em; margin: 0 auto; max-width: 900px; text-wrap: balance;">One good listing can change your year. <span style="font-style: italic; color: #EBF5A6;">This is a day built to win them.</span></h2>
        <p data-reveal style="font-family: 'Hanken Grotesk', sans-serif; font-size: clamp(16px, 1.7vw, 19px); font-weight: 500; line-height: 1.7; color: rgba(255,255,255,0.78); max-width: 600px; margin: 28px auto 0; text-wrap: pretty;">Thirty brands. Fifty buyers. One room. The shortest path between a founder-run brand and a shelf that matters.</p>
      </div>
    </section>

    <!-- ============ EVENT DETAILS ============ -->
    <section id="details" class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 100px 44px;">
      <div data-reveal style="font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #1E1BD1; margin-bottom: 24px;">Event details</div>
      <h2 data-reveal style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(30px, 4.4vw, 52px); line-height: 1.08; letter-spacing: -0.02em; margin: 0 0 50px; max-width: 700px; color: #14141C; text-wrap: pretty;">The shape of the day.</h2>
      <div data-reveal class="mtb-grid-4" style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(26,26,34,0.1); border: 1px solid rgba(26,26,34,0.1); border-radius: 16px; overflow: hidden;">
        {details.map((d) => (
          <div style="background: #FFFFFF; padding: 34px 28px;">
            <div style="font-family: 'Newsreader', Georgia, serif; font-style: italic; font-weight: 500; font-size: 22px; color: #1E1BD1; margin-bottom: 18px;">{d.n}</div>
            <div style="font-family: 'Hanken Grotesk', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.14em; text-transform: uppercase; color: #8A8A95; margin-bottom: 8px;">{d.k}</div>
            <div style="font-family: 'Hanken Grotesk', sans-serif; font-weight: 800; font-size: 24px; letter-spacing: -0.02em; color: #14141C; margin-bottom: 12px;">{d.v}</div>
            <p style="font-family: 'Hanken Grotesk', sans-serif; font-size: 14px; font-weight: 500; line-height: 1.6; color: #55555F; margin: 0;">{d.note}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ THE VENUE ============ -->
    <section style="background: #FFFFFF; border-top: 1px solid rgba(26,26,34,0.1); border-bottom: 1px solid rgba(26,26,34,0.1);">
      <div class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 100px 44px;">
        <div class="mtb-grid-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">
          <div data-reveal>
            <div style="font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #1E1BD1; margin-bottom: 22px;">The venue</div>
            <h2 style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(30px, 4.4vw, 52px); line-height: 1.08; letter-spacing: -0.02em; margin: 0 0 20px; color: #14141C; text-wrap: pretty;">A Georgian house, not a conference centre.</h2>
            <p style="font-family: 'Hanken Grotesk', sans-serif; font-size: 17px; font-weight: 500; line-height: 1.7; color: #3A3A45; margin: 0 0 18px;">We hold the day in a private Georgian house in Norfolk. Good rooms, good light and a long lunch — the kind of setting that makes a buyer glad they made the drive.</p>
            <p style="font-family: 'Newsreader', Georgia, serif; font-style: italic; font-size: clamp(20px, 2.4vw, 26px); line-height: 1.25; color: #1E1BD1; margin: 0;">the room does some of the work for you.</p>
          </div>
          <div data-reveal style="border: 1px solid rgba(26,26,34,0.12); border-radius: 16px; overflow: hidden; background: linear-gradient(180deg, #EAF0FB 0%, #F7F4EC 100%);">
            <svg viewBox="0 0 600 420" width="100%" height="100%" role="img" aria-label="Illustration of a Georgian house" style="display: block;">
              <rect width="600" height="420" fill="none" />
              <!-- ground -->
              <rect x="0" y="360" width="600" height="60" fill="#E4DFCF" />
              <!-- main house body -->
              <rect x="150" y="150" width="300" height="210" fill="#FBFAF3" stroke="#1E1BD1" stroke-width="3" />
              <!-- roof -->
              <polygon points="138,150 462,150 430,108 170,108" fill="#1E1BD1" />
              <!-- chimneys -->
              <rect x="200" y="78" width="22" height="34" fill="#1E1BD1" />
              <rect x="378" y="78" width="22" height="34" fill="#1E1BD1" />
              <!-- parapet line -->
              <rect x="150" y="150" width="300" height="8" fill="#1E1BD1" />
              <!-- windows: 3 rows x 4 cols, skipping the door slot on the ground row -->
              <g fill="#EBF5A6" stroke="#1E1BD1" stroke-width="2">
                <rect x="180" y="172" width="40" height="52" />
                <rect x="248" y="172" width="40" height="52" />
                <rect x="312" y="172" width="40" height="52" />
                <rect x="380" y="172" width="40" height="52" />
                <rect x="180" y="246" width="40" height="52" />
                <rect x="380" y="246" width="40" height="52" />
              </g>
              <!-- window mullions -->
              <g stroke="#1E1BD1" stroke-width="2">
                <line x1="200" y1="172" x2="200" y2="224" /><line x1="180" y1="198" x2="220" y2="198" />
                <line x1="268" y1="172" x2="268" y2="224" /><line x1="248" y1="198" x2="288" y2="198" />
                <line x1="332" y1="172" x2="332" y2="224" /><line x1="312" y1="198" x2="352" y2="198" />
                <line x1="400" y1="172" x2="400" y2="224" /><line x1="380" y1="198" x2="420" y2="198" />
                <line x1="200" y1="246" x2="200" y2="298" /><line x1="180" y1="272" x2="220" y2="272" />
                <line x1="400" y1="246" x2="400" y2="298" /><line x1="380" y1="272" x2="420" y2="272" />
              </g>
              <!-- door -->
              <rect x="276" y="262" width="48" height="98" fill="#1E1BD1" />
              <rect x="282" y="270" width="36" height="74" fill="#EBF5A6" />
              <circle cx="300" cy="250" r="22" fill="none" stroke="#1E1BD1" stroke-width="3" />
              <!-- steps -->
              <rect x="266" y="354" width="68" height="6" fill="#1E1BD1" />
              <!-- path -->
              <polygon points="284,360 316,360 332,408 268,408" fill="#E4DFCF" stroke="#CFC8B0" stroke-width="2" />
            </svg>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ THE INVESTMENT ============ -->
    <section class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 100px 44px;">
      <div data-reveal style="background: #14141C; color: #FFFFFF; border-radius: 20px; padding: 60px 52px; text-align: center; position: relative; overflow: hidden; box-shadow: 0 30px 70px rgba(20,20,28,0.2);">
        <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(30,27,209,0.45) 0%, rgba(20,20,28,0) 60%); pointer-events: none;"></div>
        <div style="position: relative;">
          <div style="font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #EBF5A6; margin-bottom: 18px;">The investment</div>
          <div style="font-family: 'Hanken Grotesk', sans-serif; font-weight: 800; font-size: clamp(64px, 12vw, 128px); line-height: 0.9; letter-spacing: -0.04em;">£395</div>
          <p style="font-family: 'Newsreader', Georgia, serif; font-style: italic; font-size: clamp(22px, 3vw, 32px); line-height: 1.2; color: #EBF5A6; margin: 16px 0 0;">per brand, for the whole day.</p>
          <p style="font-family: 'Hanken Grotesk', sans-serif; font-size: 16px; font-weight: 500; line-height: 1.65; color: rgba(255,255,255,0.78); max-width: 540px; margin: 22px auto 0;">Your place for the day, lunch and the venue, included. Buyers attend as our guests. Apply by application — we hold thirty seats only.</p>
          <a href={TYPEFORM} target="_blank" rel="noopener" class="pill-lime" style="display: inline-block; margin-top: 32px; text-decoration: none; font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 17px 34px; border-radius: 999px; background: #EBF5A6; color: #14141C; transition: background 0.15s;">Apply now</a>
        </div>
      </div>
    </section>

    <!-- ============ HOW TO APPLY ============ -->
    <section style="background: #EBF5A6; border-top: 1px solid rgba(26,26,34,0.08);">
      <div class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 100px 44px;">
        <div data-reveal style="font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #1E1BD1; margin-bottom: 24px;">How to apply</div>
        <h2 data-reveal style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(30px, 4.4vw, 52px); line-height: 1.08; letter-spacing: -0.02em; margin: 0 0 50px; max-width: 600px; color: #14141C; text-wrap: pretty;">Three steps to a seat at the table.</h2>
        <div data-reveal class="mtb-grid-3" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px;">
          {steps.map((s) => (
            <div style="background: #FFFFFF; border: 1px solid rgba(26,26,34,0.12); border-radius: 18px; padding: 38px 34px;">
              <div style="font-family: 'Hanken Grotesk', sans-serif; font-weight: 800; font-size: 32px; letter-spacing: -0.03em; color: #1E1BD1; margin-bottom: 16px;">{s.n}</div>
              <h3 style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: 26px; line-height: 1.15; margin: 0 0 12px; color: #14141C;">{s.title}</h3>
              <p style="font-family: 'Hanken Grotesk', sans-serif; font-size: 15px; font-weight: 500; line-height: 1.65; color: #44444F; margin: 0;">{s.body}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ FAQs ============ -->
    <section id="faqs" class="forge-pad" style="max-width: 880px; margin: 0 auto; padding: 100px 44px;">
      <div data-reveal style="font-family: 'Hanken Grotesk', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; color: #1E1BD1; margin-bottom: 24px; text-align: center;">FAQs</div>
      <h2 data-reveal style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(30px, 4.4vw, 50px); line-height: 1.08; letter-spacing: -0.02em; margin: 0 0 48px; color: #14141C; text-align: center;">The questions we get asked.</h2>
      <div data-reveal style="display: flex; flex-direction: column; gap: 12px;">
        {faqs.map((f) => (
          <details class="mtb-faq" style="background: #FFFFFF; border: 1px solid rgba(26,26,34,0.12); border-radius: 14px; overflow: hidden;">
            <summary style="display: flex; align-items: center; gap: 18px; padding: 24px 28px;">
              <span style="flex: 1; font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: 21px; line-height: 1.3; color: #14141C;">{f.q}</span>
              <span class="mtb-faq-chev" aria-hidden="true" style="flex-shrink: 0; color: #1E1BD1; font-size: 24px; font-weight: 300; transition: transform 0.25s;">+</span>
            </summary>
            <p style="margin: 0; padding: 0 28px 26px; font-family: 'Hanken Grotesk', sans-serif; font-size: 15.5px; font-weight: 500; line-height: 1.7; color: #44444F;">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <!-- ============ FOOTER CTA ============ -->
    <footer style="background: #14141C; color: #FFFFFF;">
      <div class="forge-pad" style="max-width: 1160px; margin: 0 auto; padding: 96px 44px 52px;">
        <div data-reveal style="text-align: center; padding-bottom: 56px; border-bottom: 1px solid rgba(255,255,255,0.18);">
          <h2 style="font-family: 'Newsreader', Georgia, serif; font-weight: 500; font-size: clamp(32px, 5vw, 64px); line-height: 1.06; letter-spacing: -0.02em; margin: 0 auto 18px; max-width: 720px;">Thirty seats. One day. <span style="font-style: italic; color: #EBF5A6;">Worth applying for.</span></h2>

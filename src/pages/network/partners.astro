---
import Base from '../../layouts/Base.astro';
import { getSettings } from '../../lib/content';

const { site, criteria } = await getSettings();
const email = site.contactEmail ?? 'hello@weforgepartnerships.com';
const bookHref = `mailto:${email}?subject=${encodeURIComponent('Partner enquiry · The Forge')}`;

const whyCards = [
  { title: 'vetted, not scraped', body: 'Every brand in the network applied, and a named human said yes. You meet businesses that are real, trading and growing.' },
  { title: 'matched, not mailed', body: 'We learn what a good client looks like for you, then introduce you when a brand reaches the moment you are right for.' },
  { title: 'year round, not annual', body: 'Introductions land month after month, with dinners, briefings and the directory keeping you in the room between them.' },
];

const headStyle = `
  input::placeholder { color: rgba(255,255,255,0.35); }
  @media (max-width: 880px) {
    .forge-nav-links { display: none !important; }
    .forge-grid-2 { grid-template-columns: 1fr !important; }
    .forge-grid-3 { grid-template-columns: 1fr !important; }
    .forge-pad { padding-left: 22px !important; padding-right: 22px !important; }
    .forge-gate-row { flex-direction: column !important; align-items: stretch !important; }
  }
`;
---

<Base
  title="The Forge — for partners who service challenger brands"
  description="Warm, year-round introductions to vetted UK food and drink challenger brands at the moment they start buying. Never a cold list."
  bodyBackground="#0A0A14"
  selectionBg="#EBF5A6"
  selectionColor="#14141C"
  focusOutline="#EBF5A6"
  path="/network/partners"
  headStyle={headStyle}
>
  <div style="font-family: 'Montserrat', -apple-system, sans-serif; color: #FFFFFF; background: #0A0A14; position: relative; overflow-x: hidden; -webkit-font-smoothing: antialiased;">

    <!-- ============ NAV ============ -->
    <nav style="position: sticky; top: 0; z-index: 100; background: rgba(10,10,20,0.82); backdrop-filter: blur(14px); border-bottom: 1px solid rgba(255,255,255,0.12);">
      <div class="forge-pad" style="max-width: 1220px; margin: 0 auto; padding: 16px 44px; display: flex; align-items: center; justify-content: space-between; gap: 24px;">
        <div style="display: flex; align-items: baseline; gap: 14px;">
          <a href="/" style="text-decoration: none; font-family: 'Arial Black', 'Helvetica Neue', Helvetica, Arial, sans-serif; font-weight: 900; font-style: italic; font-size: 25px; letter-spacing: -0.045em; color: #EBF5A6; line-height: 1;">TheForge</a>
          <span style="font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: 17px; color: rgba(255,255,255,0.6);">the partner room</span>
        </div>
        <div class="forge-nav-links" style="display: flex; align-items: center; gap: 32px; font-family: 'Montserrat', sans-serif; font-size: 12px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.65);">
          <a href="#why" style="text-decoration: none;">Why partner</a>
          <a href="#details" style="text-decoration: none;">Partnership details</a>
          <a href="/network/brands" style="text-decoration: none;">Brands</a>
          <a href="/network" style="text-decoration: none;">← Back to the hall</a>
        </div>
        <a href={bookHref} class="pill-lime" style="text-decoration: none; font-family: 'Montserrat', sans-serif; font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 11px 20px; border-radius: 999px; background: #EBF5A6; color: #14141C; transition: background 0.15s;">Book a call</a>
      </div>
    </nav>

    <!-- ============ HERO ============ -->
    <header style="border-bottom: 1px solid rgba(255,255,255,0.12); background: radial-gradient(ellipse 80% 60% at 70% 0%, rgba(30,27,209,0.35) 0%, rgba(10,10,20,0) 70%);">
      <div class="forge-pad" style="max-width: 1220px; margin: 0 auto; padding: 100px 44px 92px;">
        <div data-reveal style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #EBF5A6; margin-bottom: 30px;">For the people who service challenger brands</div>
        <h1 data-reveal style="font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: clamp(36px, 5.6vw, 74px); line-height: 1.02; letter-spacing: -0.03em; margin: 0 0 22px; max-width: 1000px; text-wrap: pretty;">Trade shows happen once a year. The brands you want are growing every week.</h1>
        <p data-reveal style="font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: clamp(24px, 3vw, 36px); line-height: 1.18; color: #EBF5A6; margin: 0 0 30px; max-width: 640px;">so we keep the door open all year, and we know who is behind it.</p>
        <p data-reveal style="font-family: 'Montserrat', sans-serif; font-size: clamp(16px, 1.7vw, 18px); font-weight: 500; line-height: 1.7; color: rgba(255,255,255,0.72); margin: 0 0 38px; max-width: 580px; text-wrap: pretty;">If you co pack, distribute, supply ingredients, design the packaging, build the tools or back the rounds, you already know the brands worth having are hard to catch at the right moment. We curate them, and we make the introduction warm.</p>
        <div data-reveal style="display: flex; gap: 12px; flex-wrap: wrap;">
          <a href={bookHref} class="pill-lime" style="text-decoration: none; font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 16px 30px; border-radius: 999px; background: #EBF5A6; color: #14141C; transition: background 0.15s;">Book a call</a>
          <a href="#details" class="pill-outline" style="text-decoration: none; font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 16px 30px; border-radius: 999px; background: transparent; border: 1.5px solid rgba(255,255,255,0.4); color: #FFFFFF; transition: all 0.15s;">Partnership details</a>
        </div>
      </div>
    </header>

    <!-- ============ WHY PARTNER ============ -->
    <section id="why" class="forge-pad" style="max-width: 1220px; margin: 0 auto; padding: 100px 44px;">
      <div data-reveal style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #EBF5A6; margin-bottom: 24px;">Why partner</div>
      <h2 data-reveal style="font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: clamp(30px, 4.2vw, 54px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 56px; max-width: 820px; text-wrap: pretty;">Warm introductions to brands that fit what you do. Never a cold list.</h2>
      <div data-reveal class="forge-grid-3" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: rgba(255,255,255,0.14); border: 1px solid rgba(255,255,255,0.14); border-radius: 16px; overflow: hidden;">
        {whyCards.map((c) => (
          <div style="background: #0E0E1A; padding: 36px 32px;">
            <div style="font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: 23px; color: #EBF5A6; margin-bottom: 12px;">{c.title}</div>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 14.5px; font-weight: 500; line-height: 1.65; color: rgba(255,255,255,0.72); margin: 0;">{c.body}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ============ THE BRANDS ============ -->
    <section id="brands" style="background: #0E0E1A; border-top: 1px solid rgba(255,255,255,0.12); border-bottom: 1px solid rgba(255,255,255,0.12);">
      <div class="forge-pad" style="max-width: 1220px; margin: 0 auto; padding: 100px 44px;">
        <div class="forge-grid-2" style="display: grid; grid-template-columns: 1fr 1fr; gap: 60px; align-items: center;">
          <div data-reveal>
            <div style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #EBF5A6; margin-bottom: 24px;">Who is in the room</div>
            <h2 style="font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: clamp(30px, 4.2vw, 52px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 18px; text-wrap: pretty;">Founder run challenger brands at the moment they start buying properly.</h2>
            <p style="font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: clamp(22px, 2.6vw, 30px); line-height: 1.22; color: #EBF5A6; margin: 0; max-width: 480px;">past the kitchen table, before the corporates get there.</p>
          </div>
          <div data-reveal style="background: #14141F; border: 1px solid rgba(255,255,255,0.14); border-radius: 16px; padding: 36px 38px;">
            <div style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #EBF5A6; margin-bottom: 22px;">The shape of a member brand</div>
            <div>
              <div style="display: flex; justify-content: space-between; gap: 16px; padding: 13px 0; border-bottom: 1px solid rgba(255,255,255,0.12);"><span style="font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.62);">Annual revenue</span><span style="font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 14px; color: #FFFFFF;">{criteria.revenue}</span></div>
              <div style="display: flex; justify-content: space-between; gap: 16px; padding: 13px 0; border-bottom: 1px solid rgba(255,255,255,0.12);"><span style="font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.62);">Trading</span><span style="font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 14px; color: #FFFFFF;">{criteria.trading}</span></div>
              <div style="display: flex; justify-content: space-between; gap: 16px; padding: 13px 0; border-bottom: 1px solid rgba(255,255,255,0.12);"><span style="font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.62);">Run by</span><span style="font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 14px; color: #FFFFFF;">{criteria.runBy}</span></div>
              <div style="display: flex; justify-content: space-between; gap: 16px; padding: 13px 0;"><span style="font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.62);">The network</span><span style="font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 14px; color: #EBF5A6;">500 brands, capped</span></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ PARTNERSHIP DETAILS · GATED ============ -->
    <section id="details" class="forge-pad" style="max-width: 1220px; margin: 0 auto; padding: 104px 44px;">
      <div data-reveal style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 600; letter-spacing: 0.2em; text-transform: uppercase; color: #EBF5A6; margin-bottom: 24px;">Partnership details</div>

      <!-- LOCKED (default, the only pricing-free markup rendered to crawlers) -->
      <div id="gate-locked">
        <div class="forge-grid-2" style="display: grid; grid-template-columns: 1.05fr 1fr; gap: 60px; align-items: center;">
          <div>
            <h2 style="font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: clamp(30px, 4.2vw, 52px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 18px; max-width: 560px; text-wrap: pretty;">Three ways to partner. We will show you, properly.</h2>
            <p style="font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: clamp(22px, 2.6vw, 30px); line-height: 1.22; color: #EBF5A6; margin: 0 0 20px; max-width: 500px;">every partnership starts with a conversation, not a contract.</p>
            <p style="font-family: 'Montserrat', sans-serif; font-size: 15px; font-weight: 500; line-height: 1.7; color: rgba(255,255,255,0.68); margin: 0; max-width: 480px; text-wrap: pretty;">Leave your work email and we will open the partnership details here, including the three tiers and founding partner pricing. We will also drop you a line, a human one.</p>
          </div>
          <div style="background: #14141F; border: 1px solid rgba(235,245,166,0.3); border-radius: 16px; padding: 40px 40px 36px; position: relative; overflow: hidden;">
            <div style="position: absolute; inset: 0; background: radial-gradient(ellipse at 50% 0%, rgba(30,27,209,0.3) 0%, rgba(10,10,20,0) 65%); pointer-events: none;"></div>
            <div style="position: relative;">
              <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 22px;">
                <div style="width: 30px; height: 30px; border-radius: 8px; background: rgba(235,245,166,0.14); border: 1px solid rgba(235,245,166,0.4); display: flex; align-items: center; justify-content: center; font-size: 13px; color: #EBF5A6; font-family: 'Montserrat', sans-serif; font-weight: 700;">✦</div>
                <div style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #EBF5A6;">Tiers &amp; founding pricing</div>
              </div>
              <div style="font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: 24px; line-height: 1.25; color: #FFFFFF; margin-bottom: 26px;">tell us where to find you, and we will open the room.</div>
              <form id="gate-form" class="forge-gate-row" style="display: flex; gap: 10px; align-items: stretch;" novalidate>
                <input id="gate-email" type="email" name="email" autocomplete="email" placeholder="you@yourcompany.co.uk" style="flex: 1; min-width: 0; font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 500; color: #FFFFFF; background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.25); border-radius: 999px; padding: 14px 22px; outline: none;" />
                <button id="gate-submit" type="submit" class="pill-lime" style="font-family: 'Montserrat', sans-serif; font-size: 12.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 14px 26px; border-radius: 999px; background: #EBF5A6; color: #14141C; border: none; cursor: pointer; transition: background 0.15s; white-space: nowrap;">View details</button>
              </form>
              <div id="gate-error" role="alert" style="display: none; font-family: 'Montserrat', sans-serif; font-size: 12.5px; font-weight: 600; color: #F0A8A8; margin-top: 12px;"></div>
              <div style="font-family: 'Montserrat', sans-serif; font-size: 11.5px; font-weight: 500; color: rgba(255,255,255,0.45); margin-top: 16px; line-height: 1.5;">No newsletter, no nurture sequence. One email from a named human, and the details unlocked here.</div>
            </div>
          </div>
        </div>
      </div>

      <!-- UNLOCKED (populated client-side from /api/unlock — never prerendered) -->
      <div id="gate-unlocked" style="display: none;"></div>
    </section>

    <!-- ============ FOOTER ============ -->
    <footer style="border-top: 1px solid rgba(255,255,255,0.12); background: #0E0E1A;">
      <div class="forge-pad" style="max-width: 1220px; margin: 0 auto; padding: 84px 44px 52px;">
        <div data-reveal class="forge-grid-2" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 56px; align-items: end; padding-bottom: 52px; border-bottom: 1px solid rgba(255,255,255,0.16);">
          <div>
            <h2 style="font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: clamp(30px, 4vw, 50px); line-height: 1.08; letter-spacing: -0.02em; margin: 0 0 12px; max-width: 520px;">Worth a conversation?</h2>
            <p style="font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: clamp(20px, 2.4vw, 27px); line-height: 1.2; color: #EBF5A6; margin: 0 0 26px; max-width: 460px;">we answer every enquiry ourselves, usually the same day.</p>
            <a href={bookHref} class="pill-lime" style="display: inline-block; text-decoration: none; font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 16px 30px; border-radius: 999px; background: #EBF5A6; color: #14141C; transition: background 0.15s;">Book a call</a>
          </div>
          <div style="display: flex; flex-direction: column; gap: 15px;">
            <div style="display: flex; justify-content: space-between; gap: 16px; font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 500;"><span style="color: rgba(255,255,255,0.5);">Email</span><a href={`mailto:${email}`} style="text-decoration: none; color: #EBF5A6; font-weight: 600;">{email}</a></div>
            <div style="display: flex; justify-content: space-between; gap: 16px; font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 500;"><span style="color: rgba(255,255,255,0.5);">Based</span><span>{site.location}</span></div>
            <div style="display: flex; justify-content: space-between; gap: 16px; font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 500;"><span style="color: rgba(255,255,255,0.5);">Live from</span><span>{site.launchDate}</span></div>
            <div style="display: flex; justify-content: space-between; gap: 16px; font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 500;"><span style="color: rgba(255,255,255,0.5);">Part of</span><span>Bloomco</span></div>
          </div>
        </div>
        <div style="display: flex; flex-wrap: wrap; justify-content: space-between; align-items: center; gap: 18px; margin-top: 34px;">
          <a href="/" style="text-decoration: none; font-family: 'Arial Black', Helvetica, sans-serif; font-weight: 900; font-style: italic; font-size: 28px; letter-spacing: -0.05em; color: #EBF5A6;">TheForge</a>
          <div style="display: flex; flex-wrap: wrap; gap: 18px 30px; font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 500; letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.5);">
            <a href="/network" style="text-decoration: none;">← The hall</a>
            <span>© 2026 The Forge · Bloomco</span>
          </div>
        </div>
      </div>
    </footer>

  </div>

  <script>
    const STORAGE_KEY = 'forge_partner_gate_email';
    const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

    const locked = document.getElementById('gate-locked')!;
    const unlocked = document.getElementById('gate-unlocked')!;
    const form = document.getElementById('gate-form') as HTMLFormElement | null;
    const input = document.getElementById('gate-email') as HTMLInputElement | null;
    const errorEl = document.getElementById('gate-error')!;

    const esc = (s: string) =>
      String(s).replace(/[&<>"']/g, (c) =>
        ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]!)
      );

    function showError(msg: string) {
      errorEl.textContent = msg;
      errorEl.style.display = 'block';
    }
    function clearError() {
      errorEl.textContent = '';
      errorEl.style.display = 'none';
    }

    function tierCard(t: any) {
      const features = t.features.map((f: string) =>
        `<div>${esc(f)}</div>`).join('');
      if (t.highlight) {
        const badge = t.badge
          ? `<div style="position: absolute; top: 16px; right: 16px; font-family: 'Montserrat', sans-serif; font-size: 9.5px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase; color: #EBF5A6; background: #14141C; padding: 5px 10px; border-radius: 999px;">${esc(t.badge)}</div>`
          : '';
        return `
          <div style="background: #EBF5A6; color: #14141C; border-radius: 16px; padding: 34px 32px; display: flex; flex-direction: column; position: relative; overflow: hidden;">
            ${badge}
            <div style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: #1E1BD1; margin-bottom: 20px;">${esc(t.name)}</div>
            <div style="font-family: 'Arial Black', Helvetica, sans-serif; font-weight: 900; font-style: italic; font-size: 50px; line-height: 0.9; letter-spacing: -0.04em; margin-bottom: 5px;">${esc(t.price)}</div>
            <div style="font-family: 'Montserrat', sans-serif; font-size: 12px; font-weight: 600; color: rgba(20,20,28,0.6); margin-bottom: 24px;">${esc(t.priceNote)}</div>
            <div style="display: flex; flex-direction: column; gap: 11px; font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 500; color: #2C2C36; line-height: 1.45; flex: 1;">${features}</div>
          </div>`;
      }
      return `
        <div style="background: #14141F; border: 1px solid rgba(255,255,255,0.14); border-radius: 16px; padding: 34px 32px; display: flex; flex-direction: column;">
          <div style="font-family: 'Montserrat', sans-serif; font-size: 11px; font-weight: 700; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.6); margin-bottom: 20px;">${esc(t.name)}</div>
          <div style="font-family: 'Arial Black', Helvetica, sans-serif; font-weight: 900; font-style: italic; font-size: 50px; line-height: 0.9; letter-spacing: -0.04em; color: #FFFFFF; margin-bottom: 5px;">${esc(t.price)}</div>
          <div style="font-family: 'Montserrat', sans-serif; font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.5); margin-bottom: 24px;">${esc(t.priceNote)}</div>
          <div style="display: flex; flex-direction: column; gap: 11px; font-family: 'Montserrat', sans-serif; font-size: 14px; font-weight: 500; color: rgba(255,255,255,0.75); line-height: 1.45; flex: 1;">${features}</div>
        </div>`;
    }

    function renderUnlocked(data: any) {
      const cards = data.tiers.map(tierCard).join('');
      const mailto = `mailto:${data.contactEmail}?subject=${encodeURIComponent('Partner enquiry · The Forge')}`;
      unlocked.innerHTML = `
        <div class="forge-grid-2" style="display: grid; grid-template-columns: 1.05fr 1fr; gap: 40px; align-items: end; margin-bottom: 44px;">
          <div>
            <h2 style="font-family: 'Montserrat', sans-serif; font-weight: 800; font-size: clamp(30px, 4.2vw, 52px); line-height: 1.05; letter-spacing: -0.025em; margin: 0 0 18px; max-width: 560px; text-wrap: pretty;">Three ways to partner.</h2>
            <p style="font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-size: clamp(22px, 2.6vw, 30px); line-height: 1.22; color: #EBF5A6; margin: 0; max-width: 520px;">every partnership starts with a conversation, not a contract.</p>
          </div>
          <div style="font-family: 'Montserrat', sans-serif; font-size: 12.5px; font-weight: 600; color: rgba(255,255,255,0.5); text-align: right;">Unlocked for ${esc(data.email)}</div>
        </div>
        <div class="forge-grid-3" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px;">${cards}</div>
        <div style="display: flex; flex-wrap: wrap; gap: 18px 28px; align-items: center; justify-content: space-between; margin-top: 30px;">
          <p style="font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 500; line-height: 1.6; color: rgba(255,255,255,0.62); margin: 0; max-width: 600px;">${esc(data.footnote)}</p>
          <a href="${mailto}" class="pill-lime" style="white-space: nowrap; text-decoration: none; font-family: 'Montserrat', sans-serif; font-size: 13px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 16px 30px; border-radius: 999px; background: #EBF5A6; color: #14141C; transition: background 0.15s;">Book a call</a>
        </div>`;
      locked.style.display = 'none';
      unlocked.style.display = 'block';
    }

    async function unlock(email: string, returning: boolean) {
      const res = await fetch('/api/unlock', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, returning }),
      });
      const data = await res.json();
      if (!res.ok || !data.ok) {
        throw new Error(data?.error || 'Something went wrong. One more try?');
      }
      return data;
    }

    // Returning visitor — re-open the room without sending a fresh lead.
    let savedEmail = '';
    try { savedEmail = localStorage.getItem(STORAGE_KEY) || ''; } catch {}
    if (savedEmail) {
      unlock(savedEmail, true)
        .then(renderUnlocked)
        .catch(() => { /* fall back to the locked gate */ });
    }

    if (form && input) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = input.value.trim();
        if (!EMAIL_RE.test(email)) {
          showError('That does not look like an email address. One more try?');
          return;
        }
        clearError();
        const btn = document.getElementById('gate-submit') as HTMLButtonElement;
        btn.disabled = true;
        try {
          const data = await unlock(email, false);
          try { localStorage.setItem(STORAGE_KEY, email); } catch {}
          renderUnlocked(data);
        } catch (err: any) {
          showError(err.message || 'That does not look like an email address. One more try?');
          btn.disabled = false;
        }
      });
      input.addEventListener('input', clearError);
    }
  </script>
</Base>
